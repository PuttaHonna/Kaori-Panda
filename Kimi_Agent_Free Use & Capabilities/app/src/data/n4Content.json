                    "reading": "ふみます",
                    "english": "step on"
                },
                {
                    "kanji": "壊します",
                    "reading": "こわします",
                    "english": "break, destroy"
                },
                {
                    "kanji": "盗みます",
                    "reading": "ぬすみます",
                    "english": "steal"
                }
            ]
